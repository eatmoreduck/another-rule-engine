# Another Rule Engine - Docker Compose 环境变量配置
# 复制此文件为 .env 后根据需要修改

# 数据库配置
POSTGRES_DB=yare_engine
POSTGRES_USER=yare
POSTGRES_PASSWORD=yare_secret

# 后端配置
DB_URL=jdbc:postgresql://db:5432/yare_engine
DB_USERNAME=yare
DB_PASSWORD=yare_secret
JAVA_OPTS=-Xms256m -Xmx512m

# 端口映射（如需修改）
# BACKEND_PORT=8080
# FRONTEND_PORT=3000
# DB_PORT=5432
